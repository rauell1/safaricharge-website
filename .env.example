# SafariCharge environment variables
# Copy this file to .env for local development.

# Runtime
NODE_ENV="development"

# Database
# Development default:
DATABASE_URL="file:./db/safaricharge.db"
# Production recommendation:
# DATABASE_URL="postgresql://user:password@host:5432/safaricharge?schema=public"
# Vercel Postgres support (automatically picked up when set):
# POSTGRES_PRISMA_URL=""
# POSTGRES_URL=""
# POSTGRES_URL_NON_POOLING=""
# POSTGRES_URL_NO_SSL=""

# Public app metadata
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SafariCharge"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Admin bootstrap
MAIN_ADMIN_EMAIL="admin@example.com"

# Auth and sessions
# Generate a strong value before production deployment.
SESSION_SECRET="development-session-secret-change-me"
SESSION_COOKIE_NAME="safaricharge_session"

# CORS
# Comma-separated list. Leave blank to default to NEXT_PUBLIC_APP_URL.
ALLOWED_ORIGINS="http://localhost:3000"

# Email provider
RESEND_API_KEY=""
# Sender address — must use a verified Resend domain.
# After verifying rauell.systems in Resend, set this to any address on that domain.
RESEND_FROM_EMAIL="noreply@rauell.systems"

# Scheduled jobs / cron
CRON_SECRET=""

# Optional demo toggle
ENABLE_DEMO_USERS="false"

# Optional object storage for future upload flows
S3_BUCKET=""
S3_REGION=""
S3_ENDPOINT=""
S3_PUBLIC_BASE_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
