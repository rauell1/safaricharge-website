# =============================================================================
# SafariCharge Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# =============================================================================

# --- Database ---
# SQLite (development): file:./db/safaricharge.db
# PostgreSQL (production): postgresql://user:password@host:5432/safaricharge
DATABASE_URL="file:./db/safaricharge.db"

# --- Application ---
# Public app URL used for constructing absolute URLs in emails, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SafariCharge"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# --- Admin ---
# Email address of the main administrator account.
# On first registration with this email the account is automatically granted ADMIN role.
MAIN_ADMIN_EMAIL="admin@example.com"

# --- Email (Resend) ---
# Sign up at https://resend.com to get an API key.
# Leave empty to disable transactional email (verification codes will only be logged).
RESEND_API_KEY=""

# --- Auth (NextAuth — optional, if using next-auth) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
